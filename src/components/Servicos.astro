---
/**
 * Servicos.astro
 * Grade de serviços com ícones SVG inline e animação escalonada
 * ativada por Intersection Observer.
 */

/** SVGs inline por chave — mantidos aqui para evitar arquivos extras */
const icons: Record<string, string> = {
  lightning: `<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,

  gear: `<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,

  panel: `<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>`,

  generator: `<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="2" x2="9" y2="4"/><line x1="15" y1="2" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="22"/><line x1="15" y1="20" x2="15" y2="22"/><line x1="2" y1="9" x2="4" y2="9"/><line x1="2" y1="15" x2="4" y2="15"/><line x1="20" y1="9" x2="22" y2="9"/><line x1="20" y1="15" x2="22" y2="15"/></svg>`,

  wrench: `<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
};

const servicos = [
  {
    icon: 'lightning',
    titulo: 'Instalações Elétricas',
    desc: 'Projetos e instalações em conformidade com as normas ABNT. Quadros, tomadas, iluminação e infraestrutura completa.',
  },
  {
    icon: 'gear',
    titulo: 'Manutenção de Bombas',
    desc: 'Manutenção preventiva e corretiva de bombas de recalque, piscina e incêndio. Diagnóstico e peças originais.',
  },
  {
    icon: 'panel',
    titulo: 'Painéis Elétricos',
    desc: 'Confecção, instalação e modernização de painéis elétricos com automação e proteção contra surtos.',
  },
  {
    icon: 'generator',
    titulo: 'Geradores',
    desc: 'Manutenção e suporte de geradores de emergência. Testes periódicos e disponibilidade 24/7.',
  },
  {
    icon: 'wrench',
    titulo: 'Manutenção Industrial',
    desc: 'Manutenção de máquinas e equipamentos industriais. Diagnóstico técnico e reparo especializado.',
  },
];
---

<section id="servicos" class="servicos" aria-labelledby="servicos-titulo">

  <!-- Cabeçalho da seção -->
  <div class="section-header" data-reveal style="--reveal-delay: 0ms">
    <div class="section-badge">O que fazemos</div>
    <h2 id="servicos-titulo" class="section-title">
      Serviços especializados para seu condomínio
    </h2>
    <p class="section-sub">
      Da manutenção preventiva à instalação completa —
      tudo com equipe certificada e garantia de serviço.
    </p>
  </div>

  <!-- Grade de serviços -->
  <ul class="servicos-grid" role="list">
    {servicos.map((s, i) => (
      <li
        class="servico-card"
        style={`--card-delay: ${i * 80}ms`}
      >
        <!-- Ícone em container -->
        <div class="servico-icon" set:html={icons[s.icon]} />

        <div class="servico-body">
          <h3 class="servico-titulo">{s.titulo}</h3>
          <p class="servico-desc">{s.desc}</p>
        </div>
      </li>
    ))}
  </ul>

</section>

<style>
  .servicos {
    background-color: var(--color-bg);
    padding: 120px 1.5rem;
  }

  /* ── Cabeçalho ── */
  .section-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
    margin-bottom: 4rem;
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: 4rem;
  }

  .section-badge {
    display: inline-flex;
    width: fit-content;
    padding: 0.375rem 0.875rem;
    border: 1px solid rgba(201, 162, 99, 0.3);
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    color: var(--color-gold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.625rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .section-sub {
    font-size: 1rem;
    color: var(--color-muted);
    max-width: 520px;
    line-height: 1.7;
  }

  /* ── Grade ── */
  .servicos-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
    list-style: none;
    padding: 0;
  }

  /* Centraliza o 5.º card (ímpar e último) */
  .servico-card:last-child:nth-child(odd) {
    grid-column: 1 / -1;
    justify-self: center;
    width: calc(50% - 0.75rem);
  }

  /* ── Card ── */
  .servico-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    background-color: var(--color-surface);
    transition:
      border-color 300ms ease,
      box-shadow 300ms ease,
      opacity 400ms ease,
      transform 400ms ease;
    /* Estado inicial para animação de entrada */
    opacity: 0;
    transform: translateY(20px);
  }

  .servico-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .servico-card:hover {
    border-color: rgba(201, 162, 99, 0.4);
    box-shadow: 0 0 32px rgba(201, 162, 99, 0.08);
  }

  /* ── Ícone ── */
  .servico-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    border-radius: 12px;
    background-color: rgba(201, 162, 99, 0.1);
    color: var(--color-gold);
  }

  /* ── Texto ── */
  .servico-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .servico-titulo {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .servico-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.65;
  }

  /* ── Responsividade ── */
  @media (max-width: 768px) {
    .servicos {
      padding: 80px 1.25rem;
    }

    .servicos-grid {
      grid-template-columns: 1fr;
    }

    /* Remove centralização especial em mobile (1 col) */
    .servico-card:last-child:nth-child(odd) {
      grid-column: auto;
      justify-self: auto;
      width: auto;
    }
  }
</style>

<script>
  const section = document.querySelector<HTMLElement>('#servicos');
  const cards   = document.querySelectorAll<HTMLElement>('.servico-card');

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /** Revela todos os cards imediatamente sem animação */
  function revealInstant(): void {
    cards.forEach((card) => {
      card.style.transition = 'none';
      card.classList.add('is-visible');
    });
  }

  /** Revela os cards com delay escalonado de 80ms entre cada um */
  function revealStaggered(): void {
    cards.forEach((card, i) => {
      setTimeout(() => card.classList.add('is-visible'), i * 80);
    });
  }

  let triggered = false;

  const observer = new IntersectionObserver(
    (entries) => {
      if (!entries[0].isIntersecting || triggered) return;
      triggered = true;

      if (reducedMotion) {
        revealInstant();
      } else {
        revealStaggered();
      }

      observer.disconnect();
    },
    { threshold: 0.1 }
  );

  if (section) observer.observe(section);
</script>
