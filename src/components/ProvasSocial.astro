---
/**
 * ProvasSocial.astro
 * Depoimentos de condomínios atendidos, com reveal escalonado via data-reveal.
 */

interface Depoimento {
  nome: string;
  cidade: string;
  texto: string;
  cargo: string;
}

const depoimentos: Depoimento[] = [
  {
    nome: 'Condomínio Residencial Astúrias',
    cidade: 'Praia Grande, SP',
    texto: 'A instalação dos sensores nas caixas d\'água mudou nossa rotina. Antes dependíamos de rondas manuais — hoje o sistema alerta o técnico antes mesmo de virar um problema.',
    cargo: 'Síndico responsável',
  },
  {
    nome: 'Residencial Costa Verde',
    cidade: 'Praia Grande, SP',
    texto: 'Após a modernização do painel elétrico e contrato de manutenção preventiva, não tivemos mais interrupções não programadas em 14 meses.',
    cargo: 'Administração do condomínio',
  },
  {
    nome: 'Edifício Atlântico',
    cidade: 'Santos, SP',
    texto: 'O portal do cliente nos dá visibilidade total. Consigo acompanhar cada ordem de serviço e acessar os relatórios sem precisar ligar para ninguém.',
    cargo: 'Síndico profissional',
  },
];
---

<section id="sobre" class="provas" aria-labelledby="provas-titulo">

  <!-- Cabeçalho -->
  <div class="section-header" data-reveal style="--reveal-delay: 0ms">
    <div class="section-badge">Quem atendemos</div>
    <h2 id="provas-titulo" class="section-title">
      Condomínios que confiam na JNC
    </h2>
  </div>

  <!-- Grade de depoimentos -->
  <ul class="provas-grid" role="list">
    {depoimentos.map((d, i) => (
      <li
        class="depoimento-card"
        data-reveal
        style={`--reveal-delay: ${i * 120}ms`}
      >
        <!-- Aspas decorativas -->
        <span class="aspas" aria-hidden="true">&ldquo;</span>

        <!-- Texto -->
        <blockquote class="depoimento-texto">
          <p>{d.texto}</p>
        </blockquote>

        <!-- Autoria -->
        <footer class="depoimento-autor">
          <span class="depoimento-nome">{d.nome}</span>
          <span class="depoimento-meta">{d.cidade} · {d.cargo}</span>
        </footer>
      </li>
    ))}
  </ul>

  <!-- Nota de rodapé -->
  <p class="provas-nota" data-reveal style="--reveal-delay: 360ms">
    * Depoimentos representativos. Nomes alterados a pedido dos clientes.
  </p>

</section>

<style>
  .provas {
    background-color: var(--color-bg);
    border-top: 1px solid var(--color-border);
    padding: 100px 1.5rem;
  }

  /* ── Cabeçalho ── */
  .section-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
    margin-bottom: 4rem;
  }

  .section-badge {
    display: inline-flex;
    padding: 0.375rem 0.875rem;
    border: 1px solid rgba(201, 162, 99, 0.3);
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    color: var(--color-gold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.625rem);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  /* ── Grade ── */
  .provas-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
    list-style: none;
    padding: 0;
  }

  /* ── Card ── */
  .depoimento-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 2rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    transition:
      border-color 300ms ease,
      box-shadow 300ms ease;
  }

  .depoimento-card:hover {
    border-color: rgba(201, 162, 99, 0.25);
    box-shadow: 0 0 24px rgba(201, 162, 99, 0.06);
  }

  /* Aspas decorativas */
  .aspas {
    position: absolute;
    top: -8px;
    left: 16px;
    font-size: 96px;
    line-height: 1;
    color: rgba(201, 162, 99, 0.2);
    font-family: Georgia, serif;
    pointer-events: none;
    user-select: none;
  }

  /* Texto do depoimento */
  .depoimento-texto {
    position: relative;
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.7;
    flex: 1;
    margin-top: 1.5rem; /* espaço para as aspas */
  }

  /* Autoria */
  .depoimento-autor {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .depoimento-nome {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .depoimento-meta {
    font-size: 13px;
    color: var(--color-muted);
  }

  /* Nota de rodapé */
  .provas-nota {
    text-align: center;
    font-size: 12px;
    color: var(--color-muted);
    margin-top: 2.5rem;
    opacity: 0.7;
  }

  /* ── Responsividade ── */
  @media (max-width: 1024px) {
    .provas-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .provas {
      padding: 60px 1.25rem;
    }

    .provas-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
