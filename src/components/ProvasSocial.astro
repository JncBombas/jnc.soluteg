---
/**
 * ProvasSocial.astro
 * Depoimentos com estrelas, avatares e credibilidade real.
 */
interface Depoimento {
  nome: string;
  cidade: string;
  texto: string;
  cargo: string;
  avatar: string;
}

const depoimentos: Depoimento[] = [
  {
    nome: 'Condomínio Res. Astúrias',
    cidade: 'Praia Grande, SP',
    texto: 'A IA detectou uma queda no nível da caixa d\'água às 3h da manhã e abriu a OS sozinha. Quando acordamos, o técnico já tinha resolvido. Impressionante.',
    cargo: 'Síndico responsável',
    avatar: '🏢',
  },
  {
    nome: 'Residencial Costa Verde',
    cidade: 'Praia Grande, SP',
    texto: 'Após a modernização com o sistema Soluteg, não tivemos mais interrupções não programadas em 14 meses. A manutenção preditiva realmente funciona.',
    cargo: 'Administração do condomínio',
    avatar: '🏠',
  },
  {
    nome: 'Edifício Atlântico',
    cidade: 'Santos, SP',
    texto: 'O portal com IA nos dá visibilidade total. Relatórios automáticos, ordens de serviço rastreadas — tudo sem precisar ligar para ninguém.',
    cargo: 'Síndico profissional',
    avatar: '🏗️',
  },
];
---

<section id="sobre" class="provas" aria-labelledby="provas-titulo">
  <div class="section-header-wrap" data-reveal style="--reveal-delay: 0ms">
    <div class="section-badge">Resultados reais</div>
    <h2 id="provas-titulo" class="section-title">
      Condomínios que já usam <span class="text-gradient">nossa IA</span>
    </h2>
  </div>

  <ul class="provas-grid" role="list">
    {depoimentos.map((d, i) => (
      <li class="depoimento-card" data-reveal style={`--reveal-delay: ${i * 120}ms`}>
        <!-- Estrelas -->
        <div class="stars" aria-label="5 de 5 estrelas">
          {[...Array(5)].map(() => (
            <svg viewBox="0 0 20 20" width="14" height="14" fill="#fbbf24" aria-hidden="true">
              <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.44.91-5.32L2.27 6.62l5.34-.78z"/>
            </svg>
          ))}
        </div>

        <blockquote class="depoimento-texto">
          <p>{d.texto}</p>
        </blockquote>

        <footer class="depoimento-autor">
          <span class="depoimento-avatar" aria-hidden="true">{d.avatar}</span>
          <div class="depoimento-info">
            <span class="depoimento-nome">{d.nome}</span>
            <span class="depoimento-meta">{d.cidade} · {d.cargo}</span>
          </div>
        </footer>
      </li>
    ))}
  </ul>
</section>

<style>
  .provas { background-color:var(--color-bg); border-top:1px solid var(--color-border); padding:100px 1.5rem; position:relative; }
  .provas::before { content:''; position:absolute; top:-1px; left:20%; right:20%; height:1px; background:linear-gradient(90deg,transparent,rgba(0,200,255,0.2),transparent); }

  .section-header-wrap { display:flex; flex-direction:column; align-items:center; text-align:center; gap:1.25rem; margin-bottom:3.5rem; }

  .provas-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.25rem; max-width:1100px; margin:0 auto; list-style:none; padding:0; }

  .depoimento-card { position:relative; display:flex; flex-direction:column; gap:1rem; padding:1.75rem; background-color:var(--color-surface); border:1px solid var(--color-border); border-radius:16px; overflow:hidden; transition:border-color 300ms ease, box-shadow 300ms ease, transform 300ms ease; }
  .depoimento-card:hover { border-color:rgba(0,200,255,0.15); box-shadow:0 0 24px rgba(0,200,255,0.06); transform:translateY(-2px); }

  .stars { display:flex; gap:2px; }
  .depoimento-texto { font-size:0.9375rem; color:var(--color-muted); line-height:1.7; flex:1; }
  .depoimento-autor { display:flex; align-items:center; gap:0.75rem; padding-top:1rem; border-top:1px solid var(--color-border); }
  .depoimento-avatar { display:flex; align-items:center; justify-content:center; width:36px; height:36px; border-radius:10px; background:rgba(0,200,255,0.06); font-size:1.25rem; flex-shrink:0; border:1px solid rgba(0,200,255,0.08); }
  .depoimento-info { display:flex; flex-direction:column; gap:2px; }
  .depoimento-nome { font-size:0.875rem; font-weight:600; color:var(--color-text); line-height:1.3; }
  .depoimento-meta { font-size:0.75rem; color:var(--color-muted); }

  @media (max-width:1024px) { .provas-grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width:640px) { .provas { padding:60px 1.25rem; } .provas-grid { grid-template-columns:1fr; } }
</style>
