---
/**
 * Stats.astro
 * Barra de estatísticas com visual de IA — ícones, glow e counter animado.
 */
---

<section class="stats" aria-label="Números da empresa">
  <div class="stats-inner">

    <div class="stat-item" data-reveal style="--reveal-delay: 0ms">
      <div class="stat-icon">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <span
        class="stat-number"
        data-target="7"
        data-suffix="+"
        aria-label="Mais de 7 anos de experiência"
      >0+</span>
      <span class="stat-label">Anos de experiência</span>
    </div>

    <div class="stat-divider" aria-hidden="true"></div>

    <div class="stat-item" data-reveal style="--reveal-delay: 100ms">
      <div class="stat-icon">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
      </div>
      <span
        class="stat-number"
        data-target="100"
        data-suffix="+"
        aria-label="Mais de 100 condomínios atendidos"
      >0+</span>
      <span class="stat-label">Condomínios atendidos</span>
    </div>

    <div class="stat-divider" aria-hidden="true"></div>

    <div class="stat-item" data-reveal style="--reveal-delay: 200ms">
      <div class="stat-icon stat-icon-ai">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2a10 10 0 0 1 10 10 10 10 0 0 1-10 10A10 10 0 0 1 2 12"/>
          <circle cx="12" cy="12" r="3"/>
          <path d="M2 12h4M18 12h4M12 2v4M12 18v4"/>
        </svg>
      </div>
      <span
        class="stat-number"
        data-target="24"
        data-suffix="/7"
        aria-label="Monitoramento 24/7"
      >0/7</span>
      <span class="stat-label">Monitoramento IA</span>
    </div>

    <div class="stat-divider" aria-hidden="true"></div>

    <div class="stat-item" data-reveal style="--reveal-delay: 300ms">
      <div class="stat-icon">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
      </div>
      <span
        class="stat-region"
        aria-label="Região de atuação: Baixada Santista"
      >Baixada Santista</span>
      <span class="stat-label">Região de atuação</span>
    </div>

  </div>
</section>

<style>
  .stats {
    background: linear-gradient(180deg, var(--color-surface) 0%, var(--color-bg) 100%);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 48px 1.5rem;
    position: relative;
  }

  /* Subtle glow line on top */
  .stats::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 20%;
    right: 20%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.3), transparent);
  }

  .stats-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 1000px;
    margin: 0 auto;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    flex: 1;
    text-align: center;
    padding: 0 2rem;
  }

  .stat-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(0, 200, 255, 0.06);
    border: 1px solid rgba(0, 200, 255, 0.1);
    color: var(--color-primary);
    margin-bottom: 4px;
  }

  .stat-icon-ai {
    animation: glow-pulse 3s ease-in-out infinite;
  }

  .stat-number {
    display: block;
    font-size: 40px;
    font-weight: 700;
    line-height: 1;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
  }

  .stat-region {
    display: block;
    font-size: clamp(18px, 2.2vw, 26px);
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-text);
    opacity: 0;
    transition: opacity 600ms ease;
  }

  .stat-region.is-visible {
    opacity: 1;
  }

  .stat-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .stat-divider {
    align-self: center;
    flex-shrink: 0;
    width: 1px;
    height: 48px;
    background: linear-gradient(180deg, transparent, var(--color-border-light), transparent);
  }

  @media (max-width: 768px) {
    .stats-inner {
      flex-direction: column;
      gap: 1.5rem;
    }

    .stat-divider {
      width: 48px;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--color-border-light), transparent);
    }

    .stat-item { padding: 0; }
    .stat-number { font-size: 32px; }
  }
</style>

<script>
  const section  = document.querySelector<HTMLElement>('.stats');
  const counters = document.querySelectorAll<HTMLElement>('.stat-number');
  const regionEl = document.querySelector<HTMLElement>('.stat-region');

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /** Anima o counter de 0 até `target` em `duration` ms com easeOutQuart. */
  function animateCounter(
    el: HTMLElement,
    target: number,
    suffix: string,
    duration: number
  ): void {
    const startTime = performance.now();

    function step(now: number): void {
      const elapsed  = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const eased   = 1 - Math.pow(1 - progress, 4);
      const current = Math.round(eased * target);
      el.textContent = `${current}${suffix}`;
      if (progress < 1) requestAnimationFrame(step);
    }

    requestAnimationFrame(step);
  }

  let triggered = false;

  const observer = new IntersectionObserver(
    (entries) => {
      if (!entries[0].isIntersecting || triggered) return;
      triggered = true;

      counters.forEach((el) => {
        const target = Number(el.dataset.target ?? '0');
        const suffix = el.dataset.suffix ?? '';

        if (reducedMotion) {
          el.textContent = `${target}${suffix}`;
        } else {
          animateCounter(el, target, suffix, 900);
        }
      });

      regionEl?.classList.add('is-visible');
      observer.disconnect();
    },
    { threshold: 0.3 }
  );

  if (section) observer.observe(section);
</script>
