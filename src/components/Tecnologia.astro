<script>
  const section = document.querySelector<HTMLElement>('.tecnologia');
  const pilares = document.querySelectorAll<HTMLElement>('.tec-pilar');
  const screens = document.querySelectorAll<HTMLElement>('.tec-screen');

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /** Ativa o pilar e a tela correspondente pelo índice */
  function setActive(index: number): void {
    pilares.forEach((p, i) => p.classList.toggle('is-active', i === index));
    screens.forEach((s, i) => s.classList.toggle('is-active', i === index));
  }

  // ── Observer para fade-in da seção inteira ──
  const sectionObserver = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) {
        section?.classList.add('is-visible');
        sectionObserver.disconnect();
      }
    },
    { threshold: 0.05 }
  );

  if (section) sectionObserver.observe(section);

  // ── Observer para troca de tela conforme pilar ativo ──
  // rootMargin cria um "hotspot" nos 40% centrais do viewport
  const pilarObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const index = Number((entry.target as HTMLElement).dataset.pilarIndex ?? '0');
          setActive(index);
        }
      });
    },
    {
      rootMargin: '-30% 0px -30% 0px',
      threshold: 0,
    }
  );

  // Pilar 0 começa ativo por padrão
  setActive(0);

  // Troca de tela por scroll só em desktop (mockup sticky) — não no mobile/tablet
  function initPilarObserver(): void {
    if (window.innerWidth <= 1024) return;
    pilares.forEach((p) => pilarObserver.observe(p));
  }

  // Aguarda o layout ser calculado
  if (!reducedMotion) {
    requestAnimationFrame(initPilarObserver);
  }
</script>
