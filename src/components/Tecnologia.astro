---
/**
 * Tecnologia.astro
 * Seção com 3 pilares IoT/IA e mockup sticky com troca de tela.
 */
const checkIcon = `<svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2 8 6 12 14 4"/></svg>`;

interface Pilar {
  id: string;
  icone: 'gota' | 'mensagem' | 'documento';
  titulo: string;
  desc: string;
  features: string[];
}

const pilares: Pilar[] = [
  {
    id: 'pilar-iot',
    icone: 'gota',
    titulo: 'IA que monitora em tempo real',
    desc: "Sensores IoT + algoritmos de IA analisam dados a cada 30 segundos. Predição de falhas, alertas automáticos e histórico completo — tudo no seu celular.",
    features: [
      'Análise preditiva por machine learning',
      'Histórico de 30 dias com tendências',
      'Alertas inteligentes configuráveis',
    ],
  },
  {
    id: 'pilar-wpp',
    icone: 'mensagem',
    titulo: 'Automação inteligente via WhatsApp',
    desc: 'Quando a IA detecta anomalia, abre OS automaticamente e notifica o técnico — sem intervenção humana. Tempo de resposta: 3 segundos.',
    features: [
      'OS aberta automaticamente pela IA',
      'Técnico notificado em 3 segundos',
      'Confirmação de atendimento rastreada',
    ],
  },
  {
    id: 'pilar-portal',
    icone: 'documento',
    titulo: 'Portal com inteligência de dados',
    desc: 'Relatórios gerados por IA, dashboards em tempo real e documentos organizados. Tudo em um portal exclusivo para o síndico.',
    features: [
      'Relatórios automáticos por IA',
      'Orçamentos com assinatura digital',
      'Dashboard de performance em tempo real',
    ],
  },
];
---

<section id="tecnologia" class="tecnologia" aria-labelledby="tec-titulo">
  <div class="section-header-wrap" data-reveal style="--reveal-delay: 0ms">
    <div class="section-badge">Tecnologia exclusiva</div>
    <h2 id="tec-titulo" class="section-title">
      <span class="text-gradient">Inteligência Artificial</span> que trabalha enquanto você dorme
    </h2>
    <p class="section-sub">
      O Sistema <img src="/1aa.png" alt="Soluteg" class="inline-logo" width="56" height="17" loading="lazy" decoding="async" /> usa IA para monitorar, prever falhas e agir automaticamente — 24/7.
    </p>
  </div>

  <div class="tec-body">
    <div class="tec-pillars">
      {pilares.map((p, i) => (
        <article class="tec-pilar" id={p.id} data-pilar-index={i} aria-label={p.titulo}>
          <div class="pilar-icon-wrap">
            {p.icone === 'gota' && (
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
            )}
            {p.icone === 'mensagem' && (
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            )}
            {p.icone === 'documento' && (
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            )}
          </div>
          <div class="pilar-content">
            <h3 class="pilar-titulo">{p.titulo}</h3>
            <p class="pilar-desc">{p.desc}</p>
            <ul class="pilar-features" role="list">
              {p.features.map((f) => (
                <li class="pilar-feature">
                  <span class="feature-check" set:html={checkIcon} />
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>

    <aside class="tec-mockup-col" aria-hidden="true">
      <div class="tec-phone-glow"></div>
      <div class="tec-phone">
        <div class="phone-notch"></div>
        <div class="phone-screens-area">
          <!-- Tela 1 — IoT -->
          <div class="tec-screen is-active" data-screen="0">
            <div class="app-topbar"><span class="topbar-title">Caixas d'água</span><span class="app-live"><span class="live-dot"></span>IA ativa</span></div>
            <div class="app-card"><div class="app-card-row"><span class="lbl">Nível atual</span><span class="val">71%</span></div><div class="lvl-track"><div class="lvl-fill" style="width:71%"></div></div></div>
            <div class="app-badges-row"><span class="bdg bdg-red"><span class="bdg-dot"></span>SCI 20%</span><span class="bdg bdg-yellow"><span class="bdg-dot"></span>Alerta 80%</span></div>
            <div class="app-chart-wrap"><p class="chart-lbl">Predição IA — 24h</p><svg viewBox="0 0 200 52" fill="none" class="chart-svg" aria-hidden="true"><defs><linearGradient id="g1" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#00c8ff" stop-opacity="0.2"/><stop offset="100%" stop-color="#00c8ff" stop-opacity="0"/></linearGradient></defs><path d="M0 40 L25 33 L50 27 L75 30 L100 20 L100 52 L0 52Z" fill="url(#g1)"/><path d="M0 40 L25 33 L50 27 L75 30 L100 20" stroke="#00c8ff" stroke-width="1.5" stroke-linecap="round"/><path d="M100 20 L125 16 L150 19 L175 14 L200 12" stroke="#7c3aed" stroke-width="1.5" stroke-dasharray="4 3" stroke-linecap="round"/><circle cx="100" cy="20" r="3" fill="#00c8ff"/></svg></div>
          </div>
          <!-- Tela 2 — WhatsApp -->
          <div class="tec-screen" data-screen="1">
            <div class="app-topbar"><span class="topbar-title">Soluteg IA</span><span class="wpp-badge">WhatsApp</span></div>
            <div class="wpp-messages">
              <div class="wpp-bubble wpp-system"><p class="wpp-label">Soluteg IA</p><p class="wpp-text">⚠️ <strong>Nível crítico 15%</strong> detectado pela IA. OS #0047 aberta automaticamente.</p><span class="wpp-time">14h28</span></div>
              <div class="wpp-bubble wpp-system"><p class="wpp-label">Soluteg IA</p><p class="wpp-text">🔧 Técnico João notificado. Resposta: <strong>3s</strong></p><span class="wpp-time">14h28</span></div>
              <div class="wpp-bubble wpp-confirm"><p class="wpp-label">Técnico João</p><p class="wpp-text">✅ Confirmado. Chego em ~20 min.</p><span class="wpp-time">14h32</span></div>
            </div>
          </div>
          <!-- Tela 3 — Portal -->
          <div class="tec-screen" data-screen="2">
            <div class="app-topbar"><span class="topbar-title">Portal IA</span></div>
            <div class="portal-lbl">Ordens de Serviço</div>
            <ul class="portal-list" role="list">
              <li class="portal-item"><div class="p-icon p-icon-ok"><svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="2 8 6 12 14 4"/></svg></div><div class="p-body"><span class="p-title">Reparo bomba piscina</span><span class="p-meta">Concluída · 06/04</span></div><span class="p-status p-done">Concluída</span></li>
              <li class="portal-item"><div class="p-icon p-icon-ok"><svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="2 8 6 12 14 4"/></svg></div><div class="p-body"><span class="p-title">Instalação painel</span><span class="p-meta">Concluída · 15/03</span></div><span class="p-status p-done">Concluída</span></li>
              <li class="portal-item"><div class="p-icon p-icon-pend"><svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="8" cy="8" r="6"/><polyline points="8 5 8 8 10 10"/></svg></div><div class="p-body"><span class="p-title">Manutenção gerador</span><span class="p-meta">Agendada · 28/04</span></div><span class="p-status p-pend">Agendada</span></li>
            </ul>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <div class="tec-cta">
    <p class="tec-cta-text">Quer IA no seu condomínio?</p>
    <a href="#contato" class="tec-cta-btn">Agendar Demonstração Grátis</a>
  </div>
</section>

<style>
  .tecnologia { background-color: var(--color-surface); border-top: 1px solid var(--color-border); padding: 100px 1.5rem; opacity: 0; transition: opacity 600ms ease; position: relative; }
  .tecnologia.is-visible { opacity: 1; }
  .tecnologia::before { content:''; position: absolute; top:-1px; left:15%; right:15%; height:1px; background: linear-gradient(90deg, transparent, rgba(0,200,255,0.2), transparent); }

  .section-header-wrap { display:flex; flex-direction:column; align-items:center; text-align:center; gap:1.25rem; max-width:640px; margin:0 auto 4rem; }
  .inline-logo { display:inline-block; vertical-align:middle; height:1.6em; width:auto; opacity:0.85; margin:0 4px; position:relative; top:0.05em; }

  .tec-body { display:flex; align-items:flex-start; gap:3.5rem; max-width:1100px; margin:0 auto; }
  .tec-pillars { flex:1; display:flex; flex-direction:column; }
  .tec-pilar { display:flex; gap:1.5rem; padding:2rem 1.5rem; border-left:3px solid transparent; transition: border-color 300ms ease, background-color 300ms ease; border-radius:0 12px 12px 0; }
  .tec-pilar.is-active { border-left-color: var(--color-primary); background-color: rgba(0,200,255,0.03); }

  .pilar-icon-wrap { display:flex; align-items:flex-start; justify-content:center; flex-shrink:0; width:44px; height:44px; border-radius:10px; background:rgba(0,200,255,0.06); border:1px solid rgba(0,200,255,0.1); color:var(--color-primary); padding-top:11px; }
  .tec-pilar:first-child .pilar-icon-wrap { animation: glow-pulse 3s ease-in-out infinite; }
  .pilar-content { display:flex; flex-direction:column; gap:0.75rem; }
  .pilar-titulo { font-size:1.125rem; font-weight:600; color:var(--color-text); line-height:1.3; }
  .pilar-desc { font-size:0.9rem; color:var(--color-muted); line-height:1.7; }
  .pilar-features { display:flex; flex-direction:column; gap:0.5rem; list-style:none; padding:0; margin-top:0.25rem; }
  .pilar-feature { display:flex; align-items:center; gap:0.625rem; font-size:0.875rem; color:var(--color-muted); }
  .feature-check { display:flex; align-items:center; justify-content:center; flex-shrink:0; width:20px; height:20px; border-radius:50%; background:rgba(0,200,255,0.08); color:var(--color-primary); }

  .tec-mockup-col { flex:0 0 260px; position:sticky; top:96px; }
  .tec-phone-glow { position:absolute; width:280px; height:280px; border-radius:50%; background:radial-gradient(circle,rgba(0,200,255,0.06) 0%,transparent 70%); top:50%; left:50%; transform:translate(-50%,-50%); animation:glow-pulse 4s ease-in-out infinite; pointer-events:none; }
  .tec-phone { position:relative; width:260px; border:1.5px solid rgba(0,200,255,0.12); border-radius:44px; background-color:var(--color-bg); box-shadow: inset 0 0 0 1px rgba(255,255,255,0.03), 0 32px 80px rgba(0,0,0,0.5), 0 0 50px rgba(0,200,255,0.06); overflow:hidden; padding-bottom:1.25rem; }
  .phone-notch { width:10px; height:10px; border-radius:50%; background:rgba(0,200,255,0.12); margin:14px auto 10px; }
  .phone-screens-area { position:relative; height:420px; margin:0 10px; overflow:hidden; }

  .tec-screen { position:absolute; inset:0; display:flex; flex-direction:column; gap:0.5rem; padding:0.5rem 0; opacity:0; transition:opacity 400ms ease; pointer-events:none; overflow-y:auto; scrollbar-width:none; }
  .tec-screen::-webkit-scrollbar { display:none; }
  .tec-screen.is-active { opacity:1; pointer-events:auto; }

  .app-topbar { display:flex; align-items:center; justify-content:space-between; padding:0.5rem 0.75rem; background:rgba(0,200,255,0.04); border-radius:10px; border:1px solid rgba(0,200,255,0.06); flex-shrink:0; }
  .topbar-title { font-size:0.75rem; font-weight:600; color:var(--color-text); }
  .app-live { display:flex; align-items:center; gap:5px; font-size:0.625rem; font-weight:500; color:var(--color-primary); }
  .live-dot { display:inline-block; width:6px; height:6px; border-radius:50%; background:var(--color-primary); animation:pulse-dot 2s ease-in-out infinite; flex-shrink:0; }
  .wpp-badge { font-size:0.5625rem; font-weight:600; color:#25D366; background:rgba(37,211,102,0.08); padding:0.15rem 0.4rem; border-radius:999px; border:1px solid rgba(37,211,102,0.15); }

  .app-card { padding:0.625rem 0.75rem; border:1px solid var(--color-border); border-radius:10px; background:rgba(255,255,255,0.02); display:flex; flex-direction:column; gap:0.5rem; flex-shrink:0; }
  .app-card-row { display:flex; justify-content:space-between; align-items:center; }
  .lbl { font-size:0.625rem; font-weight:500; color:var(--color-muted); text-transform:uppercase; letter-spacing:0.07em; }
  .val { font-size:1.125rem; font-weight:700; color:var(--color-primary); }
  .lvl-track { height:7px; border-radius:999px; background:rgba(255,255,255,0.04); overflow:hidden; }
  .lvl-fill { height:100%; border-radius:999px; background:linear-gradient(90deg,var(--color-primary),var(--color-accent)); }

  .app-badges-row { display:flex; gap:0.3rem; flex-wrap:wrap; flex-shrink:0; }
  .bdg { display:inline-flex; align-items:center; gap:4px; padding:0.2rem 0.45rem; border-radius:999px; font-size:0.5625rem; font-weight:600; }
  .bdg-dot { width:5px; height:5px; border-radius:50%; flex-shrink:0; }
  .bdg-red { background:rgba(239,68,68,0.1); color:#f87171; border:1px solid rgba(239,68,68,0.15); }
  .bdg-red .bdg-dot { background:#ef4444; }
  .bdg-yellow { background:rgba(234,179,8,0.1); color:#facc15; border:1px solid rgba(234,179,8,0.15); }
  .bdg-yellow .bdg-dot { background:#eab308; }

  .app-chart-wrap { display:flex; flex-direction:column; gap:0.375rem; padding:0.625rem 0.75rem; background:rgba(255,255,255,0.02); border:1px solid var(--color-border); border-radius:10px; flex-shrink:0; }
  .chart-lbl { font-size:0.5625rem; font-weight:600; color:var(--color-accent-light); text-transform:uppercase; letter-spacing:0.07em; }
  .chart-svg { width:100%; height:auto; display:block; }

  .wpp-messages { display:flex; flex-direction:column; gap:0.5rem; padding:0 0.125rem; }
  .wpp-bubble { display:flex; flex-direction:column; gap:0.25rem; padding:0.5rem 0.625rem; border-radius:10px; border-bottom-left-radius:3px; }
  .wpp-system { background:rgba(37,211,102,0.06); border:1px solid rgba(37,211,102,0.12); }
  .wpp-confirm { background:rgba(255,255,255,0.03); border:1px solid var(--color-border); align-self:flex-end; border-radius:10px; border-bottom-right-radius:3px; }
  .wpp-label { font-size:0.5625rem; font-weight:600; color:#25D366; text-transform:uppercase; letter-spacing:0.06em; }
  .wpp-text { font-size:0.6875rem; color:var(--color-text); line-height:1.5; }
  .wpp-time { font-size:0.5625rem; color:var(--color-muted); align-self:flex-end; }

  .portal-lbl { font-size:0.5625rem; font-weight:600; color:var(--color-muted); text-transform:uppercase; letter-spacing:0.09em; padding:0 0.125rem; flex-shrink:0; }
  .portal-list { display:flex; flex-direction:column; gap:0.375rem; list-style:none; padding:0; }
  .portal-item { display:flex; align-items:center; gap:0.5rem; padding:0.5rem 0.625rem; border:1px solid var(--color-border); border-radius:8px; background:rgba(255,255,255,0.02); }
  .p-icon { display:flex; align-items:center; justify-content:center; width:22px; height:22px; border-radius:6px; flex-shrink:0; }
  .p-icon-ok { background:rgba(74,222,128,0.1); color:#4ade80; }
  .p-icon-pend { background:rgba(250,204,21,0.1); color:#facc15; }
  .p-body { display:flex; flex-direction:column; gap:1px; flex:1; min-width:0; }
  .p-title { font-size:0.6875rem; font-weight:500; color:var(--color-text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .p-meta { font-size:0.5625rem; color:var(--color-muted); }
  .p-status { font-size:0.5625rem; font-weight:600; padding:0.15rem 0.375rem; border-radius:999px; flex-shrink:0; white-space:nowrap; }
  .p-done { background:rgba(74,222,128,0.1); color:#4ade80; }
  .p-pend { background:rgba(250,204,21,0.1); color:#facc15; }

  .tec-cta { display:flex; flex-direction:column; align-items:center; gap:1.25rem; margin-top:4rem; text-align:center; }
  .tec-cta-text { font-size:1.125rem; font-weight:500; color:var(--color-muted); }
  .tec-cta-btn { display:inline-flex; align-items:center; padding:0.75rem 2rem; border-radius:10px; font-size:0.9375rem; font-weight:600; color:#fff; background:linear-gradient(135deg,#00a8e8 0%,#0077b6 100%); text-decoration:none; box-shadow:0 0 24px rgba(0,200,255,0.2); transition:box-shadow 300ms ease, transform 150ms ease; }
  .tec-cta-btn:hover { box-shadow:0 0 40px rgba(0,200,255,0.4); transform:translateY(-1px); }

  @media (max-width:1024px) {
    .tec-body { flex-direction:column; align-items:center; gap:2rem; }
    .tec-mockup-col { display:flex; justify-content:center; position:static; flex:0 0 auto; width:100%; }
    .tec-phone { width:220px; }
    .phone-screens-area { height:380px; }
    .tec-pilar { border:1px solid var(--color-border); border-left:3px solid var(--color-primary); border-radius:12px; background-color:rgba(0,200,255,0.02); }
    .tec-pilar.is-active { background-color:rgba(0,200,255,0.04); box-shadow:0 0 20px rgba(0,200,255,0.06); }
  }
  @media (max-width:768px) {
    .tecnologia { padding:80px 1.25rem; }
    .tec-pilar { padding:1.5rem 1.25rem; flex-direction:column; gap:1rem; }
    .pilar-icon-wrap { width:40px; height:40px; padding-top:9px; }
    .section-header-wrap { margin-bottom:2.5rem; }
  }
</style>

<script>
  const section = document.querySelector<HTMLElement>('.tecnologia');
  const pilares = document.querySelectorAll<HTMLElement>('.tec-pilar');
  const screens = document.querySelectorAll<HTMLElement>('.tec-screen');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function setActive(index: number): void {
    pilares.forEach((p, i) => p.classList.toggle('is-active', i === index));
    screens.forEach((s, i) => s.classList.toggle('is-active', i === index));
  }

  const sectionObserver = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) { section?.classList.add('is-visible'); sectionObserver.disconnect(); }
    },
    { threshold: 0.05 }
  );
  if (section) sectionObserver.observe(section);

  const pilarObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const index = Number((entry.target as HTMLElement).dataset.pilarIndex ?? '0');
          setActive(index);
        }
      });
    },
    { rootMargin: '-30% 0px -30% 0px', threshold: 0 }
  );

  setActive(0);

  function initPilarObserver(): void {
    if (window.innerWidth <= 1024) return;
    pilares.forEach((p) => pilarObserver.observe(p));
  }

  if (!reducedMotion) requestAnimationFrame(initPilarObserver);
</script>
