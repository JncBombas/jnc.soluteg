---
/**
 * Header.astro
 * Cabeçalho sticky com glass effect, branding JNC + Soluteg IA,
 * e navegação principal com CTA de conversão.
 */
---

<header class="site-header" role="banner">
  <div class="header-inner">

    <!-- Marca: JNC logo + Soluteg IA wordmark -->
    <a href="/" class="brand" aria-label="JNC Comércio e Serviços — página inicial">
      <img
        src="/logo-jnc.png"
        alt="JNC Comércio e Serviços"
        class="brand-jnc"
        width="40"
        height="40"
        loading="eager"
        decoding="async"
      />
      <div class="brand-text">
        <span class="brand-name">JNC Comércio e Serviços</span>
        <span class="brand-sistema">
          <span class="brand-ai-dot"></span>
          Sistema Soluteg · IA
        </span>
      </div>
    </a>

    <!-- Navegação desktop -->
    <nav class="nav-desktop" aria-label="Menu principal">
      <a href="#servicos" class="nav-link">Serviços</a>
      <a href="#tecnologia" class="nav-link">Tecnologia IA</a>
      <a href="#sobre" class="nav-link">Sobre</a>
      <a href="#contato" class="nav-link">Contato</a>
    </nav>

    <!-- CTA + Hamburger -->
    <div class="header-actions">
      <a
        href="#contato"
        class="btn-cta"
        aria-label="Agendar demonstração"
      >
        <span class="btn-cta-dot"></span>
        Agendar Demonstração
      </a>

      <!-- Botão hamburger (mobile) -->
      <button
        class="hamburger"
        id="hamburger-btn"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </button>
    </div>
  </div>

  <!-- Navegação mobile (colapsável) -->
  <nav
    class="nav-mobile"
    id="mobile-nav"
    aria-label="Menu mobile"
    aria-hidden="true"
  >
    <a href="#servicos"   class="nav-link-mobile" tabindex="-1">Serviços</a>
    <a href="#tecnologia" class="nav-link-mobile" tabindex="-1">Tecnologia IA</a>
    <a href="#sobre"      class="nav-link-mobile" tabindex="-1">Sobre</a>
    <a href="#contato"    class="nav-link-mobile" tabindex="-1">Contato</a>
    <a
      href="#contato"
      class="nav-link-mobile btn-cta-mobile"
      tabindex="-1"
    >
      Agendar Demonstração
    </a>
  </nav>
</header>

<style>
  /* ── Estrutura principal ── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    background-color: rgba(6, 6, 10, 0.85);
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    animation: fadeSlideDown 500ms ease-out both;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
  }

  /* ── Marca ── */
  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity 200ms ease;
  }

  .brand:hover {
    opacity: 0.85;
  }

  .brand-jnc {
    height: 40px;
    width: 40px;
    object-fit: contain;
    display: block;
    flex-shrink: 0;
    border-radius: 8px;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .brand-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.2;
    white-space: nowrap;
  }

  .brand-sistema {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-primary);
    line-height: 1;
    white-space: nowrap;
  }

  .brand-ai-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-primary);
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  /* ── Nav desktop ── */
  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 200ms ease;
    white-space: nowrap;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--gradient-ai);
    border-radius: 1px;
    transition: width 300ms ease;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--color-text);
    outline: none;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  /* ── Ações (CTA + hamburger) ── */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  /* ── Botão CTA desktop ── */
  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0.5rem 1.25rem;
    border: 1px solid rgba(0, 200, 255, 0.3);
    border-radius: 8px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    white-space: nowrap;
    background: rgba(0, 200, 255, 0.06);
    transition:
      background-color 200ms ease,
      border-color 200ms ease,
      box-shadow 200ms ease;
  }

  .btn-cta-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  .btn-cta:hover,
  .btn-cta:focus-visible {
    background-color: rgba(0, 200, 255, 0.12);
    border-color: rgba(0, 200, 255, 0.5);
    box-shadow: 0 0 24px rgba(0, 200, 255, 0.15);
    outline: none;
  }

  /* ── Hamburger ── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 6px;
    background: transparent;
    border: none;
    cursor: pointer;
    border-radius: 4px;
    transition: background-color 200ms ease;
  }

  .hamburger:hover {
    background-color: rgba(255, 255, 255, 0.06);
  }

  .hamburger-bar {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-muted);
    border-radius: 2px;
    transition:
      transform 300ms ease,
      opacity 300ms ease,
      background-color 200ms ease;
  }

  .hamburger[aria-expanded="true"] .hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
    background-color: var(--color-primary);
  }
  .hamburger[aria-expanded="true"] .hamburger-bar:nth-child(2) {
    opacity: 0;
  }
  .hamburger[aria-expanded="true"] .hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
    background-color: var(--color-primary);
  }

  /* ── Nav mobile ── */
  .nav-mobile {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    max-height: 0;
    transition: max-height 350ms ease;
    border-top: 1px solid transparent;
    background: rgba(6, 6, 10, 0.95);
  }

  .nav-mobile.is-open {
    max-height: 400px;
    border-top-color: var(--color-border);
  }

  .nav-link-mobile {
    padding: 0.875rem 1.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition: color 200ms ease, background-color 200ms ease;
  }

  .nav-link-mobile:hover,
  .nav-link-mobile:focus-visible {
    color: var(--color-primary);
    background-color: rgba(0, 200, 255, 0.04);
    outline: none;
  }

  .btn-cta-mobile {
    margin: 1rem 1.5rem;
    padding: 0.75rem 1.25rem;
    border: 1px solid rgba(0, 200, 255, 0.3);
    border-radius: 8px;
    text-align: center;
    color: var(--color-primary);
    border-bottom: 1px solid rgba(0, 200, 255, 0.3);
    background: rgba(0, 200, 255, 0.06);
  }

  .btn-cta-mobile:hover {
    background-color: rgba(0, 200, 255, 0.12);
  }

  /* ── Responsividade ── */
  @media (max-width: 768px) {
    .nav-desktop { display: none; }
    .btn-cta { display: none; }
    .hamburger { display: flex; }
  }

  @media (max-width: 380px) {
    .brand-name { font-size: 0.75rem; }
    .brand-sistema { display: none; }
    .header-inner { padding: 0 1rem; }
  }
</style>

<script>
  /* Controle do menu mobile */
  const btn = document.getElementById('hamburger-btn');
  const nav = document.getElementById('mobile-nav');

  if (btn && nav) {
    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isOpen));
      nav.setAttribute('aria-hidden', String(isOpen));
      nav.classList.toggle('is-open', !isOpen);

      /* Atualiza tabindex dos links */
      nav.querySelectorAll<HTMLAnchorElement>('.nav-link-mobile').forEach((link) => {
        link.tabIndex = isOpen ? -1 : 0;
      });
    });

    /* Fecha o menu ao clicar em um link interno */
    nav.querySelectorAll<HTMLAnchorElement>('.nav-link-mobile').forEach((link) => {
      link.addEventListener('click', () => {
        btn.setAttribute('aria-expanded', 'false');
        nav.setAttribute('aria-hidden', 'true');
        nav.classList.remove('is-open');
        nav.querySelectorAll<HTMLAnchorElement>('.nav-link-mobile').forEach((l) => {
          l.tabIndex = -1;
        });
      });
    });
  }
</script>
